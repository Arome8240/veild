# Veild web app — copy to .env.local and fill in contract addresses

# ── Celo mainnet contract addresses ──────────────────────────────────────────
NEXT_PUBLIC_VEILD_REGISTRY_ADDRESS=0x4565001527ac0f6fa822020f8b4c3d33e0ca0aa4
NEXT_PUBLIC_VEILD_MESSAGES_ADDRESS=0x687f4fcfeb8fcbdf1d16e187b1b3613f7f07398e
NEXT_PUBLIC_VEILD_TIPS_ADDRESS=0x031c1537779e3b5ee55533c17a48f7d008f85160
NEXT_PUBLIC_VEILD_SUBSCRIPTIONS_ADDRESS=0x2ccbb81331eaf1718b584eecfc76741a70c8f350
NEXT_PUBLIC_VEILD_POOLS_ADDRESS=0xdaa63693b90da8dea6494ff0698b55c38e5a772d
NEXT_PUBLIC_VEILD_BADGES_ADDRESS=0x14d5f9c860d4dc1908f49bfbd04e3e226eb56ae8
NEXT_PUBLIC_VEILD_GOVERNANCE_ADDRESS=0x8fc0b06649d92ccd2ecfa858d41b88b680e9910b
NEXT_PUBLIC_VEILD_AUCTION_ADDRESS=0x7b14d324548f7b2b1d9aac6a18cd814187043e51
NEXT_PUBLIC_VEILD_REFERRAL_ADDRESS=0x20a3ec86abd297e9adfb88b9147ed227ed6ed95b
NEXT_PUBLIC_VEILD_GIFTS_ADDRESS=0x2c5eb1daf529054c11c7adada2b9ec988a1adfee
NEXT_PUBLIC_VEILD_STAKING_ADDRESS=0xa51eeacff6702d3eee5018fe025b173c24e8d857
NEXT_PUBLIC_VEILD_FEE_DISTRIBUTOR_ADDRESS=0xe067d28285bd7f5f297b1a5a7be8a8c7f0823c17

# ── Pinata (IPFS avatar uploads) ─────────────────────────────────────────────
# Server-side JWT — never expose to the browser.
# Create one at https://app.pinata.cloud/developers/api-keys
PINATA_JWT=
# Public IPFS gateway used to display uploaded avatars.
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ── Stacks contract addresses ─────────────────────────────────────────────────
NEXT_PUBLIC_STACKS_REGISTRY_ADDRESS=
NEXT_PUBLIC_STACKS_TIPS_ADDRESS=

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" to point at Alfajores testnet instead of Celo mainnet
NEXT_PUBLIC_USE_TESTNET=false

# WalletConnect project ID (optional — only needed for WalletConnect modal)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Celo RPC URL override (defaults to forno.celo.org)
NEXT_PUBLIC_CELO_RPC_URL=
