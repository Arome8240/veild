# ─────────────────────────────────────────────────────────────────────────────
# Veild — Smart Contract Environment Variables
# Copy this file to .env and fill in real values.
# ⚠️  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployer ──────────────────────────────────────────────────────────────────

# Private key of the deployer wallet (without the leading 0x).
# Use a dedicated deployment wallet — NEVER your personal/main wallet.
PRIVATE_KEY=

# ── Deployed contract addresses ───────────────────────────────────────────────
# Celo Mainnet (chainId 42220)
VEILD_REGISTRY_ADDRESS=0x4565001527ac0f6fa822020f8b4c3d33e0ca0aa4
VEILD_MESSAGES_ADDRESS=0x687f4fcfeb8fcbdf1d16e187b1b3613f7f07398e

# Celo Alfajores Testnet (chainId 44787) — fill in after testnet deploy
VEILD_REGISTRY_ADDRESS_TESTNET=
VEILD_MESSAGES_ADDRESS_TESTNET=

# ── Verification ──────────────────────────────────────────────────────────────
# Single Etherscan V2 key — works for Celo mainnet, Alfajores, and all EVM chains.
# Get yours at https://etherscan.io/myapikey  (login → API Keys → Add)
# Migration guide: https://docs.etherscan.io/v2-migration
ETHERSCAN_API_KEY=

# ── RPC endpoints (optional — hardhat.config.ts has sensible defaults) ────────

CELO_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://alfajores-forno.celo-testnet.org

# ── Simulation / Sweep ────────────────────────────────────────────────────────
# Master wallet used to auto-fund simulation accounts with low CELO balance.
# Also used as destination in scripts/sweep.ts to recover simulation funds.
MASTER_PRIVATE_KEY=
MASTER_ADDRESS=

# MongoDB connection string for simulation scripts
MONGODB_URI=mongodb://localhost:27017/veild_simulation

# ── Misc ──────────────────────────────────────────────────────────────────────

# Set to "true" to print a gas report after each test run.
REPORT_GAS=
