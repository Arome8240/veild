# Veild web app — copy to .env.local and fill in contract addresses

# ── Celo mainnet contract addresses ──────────────────────────────────────────
NEXT_PUBLIC_VEILD_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_MESSAGES_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_TIPS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_SUBSCRIPTIONS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_POOLS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_BADGES_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_GOVERNANCE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_AUCTION_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_REFERRAL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_GIFTS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VEILD_STAKING_ADDRESS=0x0000000000000000000000000000000000000000

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" to point at Alfajores testnet instead of Celo mainnet
NEXT_PUBLIC_USE_TESTNET=false

# WalletConnect project ID (optional — only needed for WalletConnect modal)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
