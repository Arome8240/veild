# ─────────────────────────────────────────────────────────────────────────────
# Veild — Smart Contract Environment Variables
# Copy this file to .env and fill in real values.
# ⚠️  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Private key of the deployer wallet (without the leading 0x).
# Use a dedicated deployment wallet — NEVER your personal/main wallet.
PRIVATE_KEY=

# Celoscan API key — used to verify contract source code after deployment.
# Get one at https://celoscan.io/myapikey
CELOSCAN_API_KEY=

# ── RPC overrides (optional — hardhat.config.ts has sensible defaults) ────────

CELO_RPC_URL=https://forno.celo.org
CELO_SEPOLIA_RPC_URL=https://alfajores-forno.celo-testnet.org

# ── Misc ──────────────────────────────────────────────────────────────────────

# Set to "true" to print a gas report after each test run.
REPORT_GAS=
